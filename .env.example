# Copy to .env.local and fill in dev project values.
# Production values live in GitHub Actions secrets, not in .env.

PUBLIC_SUPABASE_URL=https://<your-dev-project-ref>.supabase.co
PUBLIC_SUPABASE_ANON_KEY=<your-dev-anon-key>

# Service-role key — only used by import/seed scripts that bypass RLS.
# NEVER commit this and NEVER expose to the client bundle.
SUPABASE_SERVICE_ROLE_KEY=<your-dev-service-role-key>
