# Copy to .env.local and fill in dev project values.
# Production values live in GitHub Actions secrets, not in .env.

# Client-side (safe to expose):
PUBLIC_SUPABASE_URL=https://<your-dev-project-ref>.supabase.co
PUBLIC_SUPABASE_ANON_KEY=<your-dev-anon-key>

# Scripts only — used by seed/import to bypass RLS and write PostGIS data.
# NEVER commit; NEVER expose to the client bundle.
SUPABASE_DB_URL=postgresql://postgres:<db-password>@db.<your-dev-project-ref>.supabase.co:5432/postgres

# Optional: only used by scripts/seed-dev.ts to attribute test fixtures
# to your auth.users.id. Sign up via the app once, then paste your id.
FORAGER_DEV_USER_ID=
